# ========================
# IntelliCampus Environment
# ========================
#
# Copy this file to .env and fill in your values.
# This is the superset of variables used across the monorepo.
# The primary runtime is the Next.js frontend in frontend/.

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/intellicampus?schema=public
DIRECT_URL=postgresql://user:password@host:5432/intellicampus?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── App URLs and Ports ────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:5000
AI_SERVICE_PORT=5000
PORT=4000

# ── Supabase (required for storage-backed uploads) ────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Providers ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# ── Pinecone (Vector DB) ──────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=intellicampus
PINECONE_INDEX_NAME=intellicampus
PINECONE_ENVIRONMENT=

# ── Semantic Cache / Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Speech / Voice (optional) ─────────────────────────────────────────────
GOOGLE_SPEECH_KEY=your-google-speech-key
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id

# ── Email / Admin / Uploads / Compiler ────────────────────────────────────
RESEND_API_KEY=
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
