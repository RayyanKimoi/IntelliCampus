# ========================
# IntelliCampus Environment
# ========================
#
# Copy this file to .env and fill in your values.
# The primary runtime is the Next.js frontend (frontend/).
# Set DATABASE_URL to your hosted PostgreSQL connection string.

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/intellicampus?schema=public
# For connection poolers (e.g. Supabase PgBouncer), also set DIRECT_URL.
# If not using a pooler, set DIRECT_URL identical to DATABASE_URL.
DIRECT_URL=postgresql://user:password@host:5432/intellicampus?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ── AI / OpenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ── Pinecone (Vector DB) ──────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=intellicampus
PINECONE_ENVIRONMENT=us-east-1

# ── Speech / Voice (optional) ─────────────────────────────────────────────
GOOGLE_SPEECH_KEY=your-google-speech-key
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id

# ── App Config ────────────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Only needed when running the ai-services microservice separately
AI_SERVICE_URL=http://localhost:5000
