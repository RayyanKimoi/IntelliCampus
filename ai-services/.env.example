# IntelliCampus ai-services environment
# The current service code loads frontend/.env by default.
# Keep this file as the reference for variables required by the AI microservice.

AI_SERVICE_PORT=5000
AI_SERVICE_URL=http://localhost:5000

# Required for semantic cache
REDIS_URL=redis://localhost:6379

# LLM / embeddings
OPENAI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Vector store
PINECONE_API_KEY=
PINECONE_INDEX_NAME=intellicampus
PINECONE_INDEX=intellicampus

# Voice
GOOGLE_SPEECH_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
