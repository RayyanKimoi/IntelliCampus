# IntelliCampus frontend environment
# Copy to frontend/.env before running pnpm dev in the frontend package.

NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/intellicampus?schema=public
DIRECT_URL=postgresql://user:password@host:5432/intellicampus?schema=public

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# App integrations
AI_SERVICE_URL=http://localhost:5000
BACKEND_URL=http://localhost:4000

# Supabase storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=intellicampus
PINECONE_ENVIRONMENT=
GOOGLE_SPEECH_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Email / OTP
RESEND_API_KEY=

# Admin bootstrap script
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Uploads and compiler
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
JDOODLE_CLIENT_ID=
JDOODLE_CLIENT_SECRET=
