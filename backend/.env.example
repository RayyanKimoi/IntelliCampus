# IntelliCampus backend environment
# Copy to backend/.env before running the legacy Express backend.

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://user:password@host:5432/intellicampus?schema=public

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# AI and vector services
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=intellicampus
PINECONE_ENVIRONMENT=

# Voice services
GOOGLE_SPEECH_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Uploads
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads
